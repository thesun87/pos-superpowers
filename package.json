{
  "name": "pos-superpowers",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter='./apps/*' --filter='./packages/*' build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @pos/api start:dev",
    "dev:web": "pnpm --filter @pos/web dev"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "@types/node": "20.12.7"
  }
}
